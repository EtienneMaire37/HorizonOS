diff -uraN gcc-15.2.0/gcc/config/horizonos.h "gcc-15.2.0 copy/gcc/config/horizonos.h"
--- gcc-15.2.0/gcc/config/horizonos.h	1970-01-01 01:00:00.000000000 +0100
+++ "gcc-15.2.0 copy/gcc/config/horizonos.h"	2026-01-17 20:39:59.380461683 +0100
@@ -0,0 +1,24 @@
+#undef TARGET_HORIZONOS
+#define TARGET_HORIZONOS 1
+
+#undef LIB_SPEC
+#define LIB_SPEC "-lc"
+
+#undef STARTFILE_SPEC
+#define STARTFILE_SPEC "crt0.o%s crti.o%s crtbegin.o%s"
+
+#undef ENDFILE_SPEC
+#define ENDFILE_SPEC "crtend.o%s crtn.o%s"
+
+#undef LINK_SPEC
+#define LINK_SPEC "%{shared:-shared} %{static:-static} %{!shared: %{!static: %{rdynamic:-export-dynamic}}}"
+
+#undef TARGET_OS_CPP_BUILTINS
+#define TARGET_OS_CPP_BUILTINS()      \
+  do {                                \
+    builtin_define ("__horizonos__");      \
+    builtin_define ("__unix__");      \
+    builtin_assert ("system=horizonos");   \
+    builtin_assert ("system=unix");   \
+    builtin_assert ("system=posix");   \
+  } while(0);
\ No newline at end of file
diff -uraN gcc-15.2.0/gcc/config.gcc "gcc-15.2.0 copy/gcc/config.gcc"
--- gcc-15.2.0/gcc/config.gcc	2025-08-08 08:51:40.435347488 +0200
+++ "gcc-15.2.0 copy/gcc/config.gcc"	2026-01-17 20:38:53.487322342 +0100
@@ -885,6 +885,13 @@
   rust_target_objs="${rust_target_objs} fuchsia-rust.o"
   target_has_targetrustm=yes
   ;;
+*-*-horizonos*)
+  extra_options="$extra_options gnu-user.opt"
+  gas=yes
+  gnu_ld=yes
+  default_use_cxa_atexit=yes
+  use_gcc_stdint=provide
+  ;;
 *-*-linux* | frv-*-*linux* | *-*-kfreebsd*-gnu | *-*-gnu* | *-*-kopensolaris*-gnu | *-*-uclinuxfdpiceabi)
   extra_options="$extra_options gnu-user.opt"
   gas=yes
@@ -1186,6 +1193,12 @@
 esac
 
 case ${target} in
+i[34567]86-*-horizonos*)
+	tm_file="${tm_file} i386/unix.h i386/att.h elfos.h glibc-stdint.h i386/i386elf.h horizonos.h gnu-user.h"
+	;;
+x86_64-*-horizonos*)
+	tm_file="${tm_file} i386/unix.h i386/att.h elfos.h glibc-stdint.h i386/i386elf.h i386/x86-64.h horizonos.h gnu-user.h"
+	;;
 aarch64*-*-elf | aarch64*-*-fuchsia* | aarch64*-*-rtems*)
 	tm_file="${tm_file} elfos.h newlib-stdint.h"
 	tm_file="${tm_file} aarch64/aarch64-elf.h aarch64/aarch64-errata.h aarch64/aarch64-elf-raw.h"
