+
+#define STUB()                                                                 \
+({                                                                           \
+	__ensure(!"STUB function was called");                                     \
+	__builtin_unreachable();                                                   \
+})
+
+namespace mlibc 
+{
+	void sys_libc_panic() 
+	{
+		sys_libc_log("!!! mlibc panic !!!");
+		sys_exit(-1);
+		__builtin_trap();
+	}
+
+	void sys_libc_log(const char* msg) 
+	{ 
+		ssize_t unused;
+		sys_write(2, msg, strlen(msg), &unused);
+	}
